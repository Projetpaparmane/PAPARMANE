---
const services = [
  { idx: "01", title: "Branding & Identité", desc: "Logos, systèmes visuels, chartes et guidelines. On donne à votre marque une voix claire et une allure inoubliable.", tags: ["Logo", "Guidelines", "Naming"] },
  { idx: "02", title: "Web Design & UX", desc: "Des interfaces élégantes et fluides, conçues pour convertir. De la maquette au design system complet.", tags: ["UI/UX", "Design System", "Prototype"] },
  { idx: "03", title: "Développement", desc: "Sites rapides, accessibles et animés. On code proprement, du front performant aux animations GSAP.", tags: ["Front-end", "GSAP", "Headless"] },
  { idx: "04", title: "Motion & Direction", desc: "Direction artistique et motion design pour donner du rythme et de l'émotion à chaque scroll.", tags: ["Motion", "Art Direction", "3D"] },
];
---
<section class="services" id="services">
  <div class="services__head">
    <p class="section-label" data-reveal><span></span>Ce que l'on fait</p>
    <h2 data-reveal>Des services pensés<br />pour aller plus loin.</h2>
  </div>
  <ul class="services__list">
    {services.map((s) => (
      <li class="service" data-reveal>
        <span class="service__idx">{s.idx}</span>
        <h3 set:html={s.title} />
        <p>{s.desc}</p>
        <div class="service__tags">{s.tags.map((t) => <span>{t}</span>)}</div>
      </li>
    ))}
  </ul>
</section>

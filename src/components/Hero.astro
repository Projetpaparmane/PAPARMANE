---
const marquee = ["Branding", "✦", "Web Design", "✦", "Direction Artistique", "✦", "Motion", "✦", "Développement", "✦", "Stratégie", "✦"];
---
<section class="hero" id="hero">
  <div class="hero__inner">
    <p class="hero__eyebrow" data-reveal>Studio créatif indépendant — Est. 2019</p>
    <h1 class="hero__title">
      <span class="line" data-reveal>Nous créons</span>
      <span class="line" data-reveal>des marques <em>qui</em></span>
      <span class="line" data-reveal>bougent<span class="dot">.</span></span>
    </h1>
    <div class="hero__meta">
      <p data-reveal>Design, direction artistique &amp; développement pour des marques ambitieuses partout dans le monde.</p>
      <a href="#work" class="btn btn--ghost" data-reveal data-link>
        Voir nos projets
        <svg viewBox="0 0 24 24" width="18" height="18"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2"/></svg>
      </a>
    </div>
  </div>

  <div class="marquee" aria-hidden="true">
    <div class="marquee__track" data-marquee>
      {[...marquee, ...marquee, ...marquee].map((w) => <span>{w}</span>)}
    </div>
  </div>
</section>

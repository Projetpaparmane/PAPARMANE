---
const projects = [
  { name: "Nova Studio", cat: "Branding · Web", year: "2025", c: "#d9ff5a" },
  { name: "Halcyon", cat: "UX · Développement", year: "2025", c: "#7c9cff" },
  { name: "Marée Haute", cat: "Identité · Motion", year: "2024", c: "#ff8a5b" },
  { name: "Oblique", cat: "Direction · 3D", year: "2024", c: "#c58cff" },
];
---
<section class="work" id="work">
  <div class="work__head">
    <p class="section-label" data-reveal><span></span>Projets sélectionnés</p>
    <h2 data-reveal>Nos derniers<br />travaux.</h2>
  </div>

  <div class="work__grid">
    {projects.map((p) => (
      <article class="project" data-reveal data-tilt style={`--c:${p.c}`}>
        <div class="project__media"><span class="project__year">{p.year}</span></div>
        <div class="project__foot">
          <div><h3>{p.name}</h3><p>{p.cat}</p></div>
          <span class="project__arrow">→</span>
        </div>
      </article>
    ))}
  </div>
</section>

---
const projects = [
  { name: "Pacini", cat: "Site web · Développement", year: "", c: "#c0392b", url: "https://pacini.com", img: "/projects/pacini.jpg" },
  { name: "Halcyon", cat: "UX · Développement", year: "2025", c: "#7c9cff", url: "", img: "" },
  { name: "Marée Haute", cat: "Identité · Motion", year: "2024", c: "#ff8a5b", url: "", img: "" },
  { name: "Oblique", cat: "Direction · 3D", year: "2024", c: "#c58cff", url: "", img: "" },
];
---
<section class="work" id="work">
  <div class="work__head">
    <p class="section-label" data-reveal><span></span>Projets sélectionnés</p>
    <h2 data-reveal>Nos derniers<br />travaux.</h2>
  </div>

  <div class="work__grid">
    {projects.map((p) => {
      const Tag = p.url ? "a" : "div";
      const linkAttrs = p.url ? { href: p.url, target: "_blank", rel: "noopener noreferrer" } : {};
      return (
        <article class="project" data-reveal data-tilt style={`--c:${p.c}`}>
          <Tag class="project__link" {...linkAttrs}>
            <div class="project__media" data-has-img={p.img ? "true" : "false"}>
              {p.img && <img src={p.img} alt={`Aperçu du projet ${p.name}`} loading="lazy" />}
              {p.year && <span class="project__year">{p.year}</span>}
            </div>
            <div class="project__foot">
              <div><h3>{p.name}</h3><p>{p.cat}</p></div>
              <span class="project__arrow">{p.url ? "↗" : "→"}</span>
            </div>
          </Tag>
        </article>
      );
    })}
  </div>
</section>
